      "parameters": {
        "jsCode": "const response = JSON.parse(\n  $input.first().json.choices[0].message.content\n);\n\n// Return action items as separate items for looping\nconst items = response.action_items.map(item => ({\n  json: {\n    ...item,\n    meeting_title: response.meeting_title,\n    meeting_date: response.date,\n    participants: response.participants.join(', '),\n    key_decisions: response.key_decisions,\n    discussion_highlights: response.discussion_highlights\n  }\n}));\n\nreturn items;\n"
