    {
      "parameters": {
        "jsCode": "const firstItem = $input.first()?.json || {};\nlet tickets = firstItem.tickets;\n\n// 1. Auto-detect the tickets array if the field name is different\nif (!tickets) {\n  for (const key in firstItem) {\n    if (Array.isArray(firstItem[key])) {\n      tickets = firstItem[key];\n      break;\n    }\n  }\n}\n\n// 2. Fallback: If it's an array itself or grouped differently\nif (!tickets && Array.isArray(firstItem)) {\n  tickets = firstItem;\n}\n\n// 3. Last resort fallback: grab all input items\nif (!tickets || tickets.length === 0) {\n  tickets = $input.all().map(item => item.json);\n}\n\n// 4. If still nothing, throw a descriptive error\nif (!tickets || tickets.length === 0) {\n  throw new Error(\"Could not find any ticket data. Input received: \" + JSON.stringify(firstItem));\n}\n\n// 5. Fetch the meeting metadata from the Groq parser node (Code in JavaScript1)\nconst metadata = $('Code in JavaScript1').first().json;\nconst jiraDomain = \"harshvarthan0310\"; // Your Jira subdomain\n\n// 6. Build ticket list\nconst ticketLines = tickets.map((t, index) => {\n  // Try to find the ticket key in various possible formats\n  const key = t.key || t.json?.key || 'Unknown-Key';\n  const originalTasks = $('Code in JavaScript1').all();\n  const summary = originalTasks[index]?.json?.title || 'Untitled Task';\n  return `• <https://${jiraDomain}.atlassian.net/browse/${key}|${key}> — ${summary}`;\n}).join('\\n');\n\n// 7. Build decisions list\nconst decisions = metadata.key_decisions\n  ? (Array.isArray(metadata.key_decisions) ? metadata.key_decisions.map(d => `• ${d}`).join('\\n') : `• ${metadata.key_decisions}`)\n  : 'None recorded';\n\n// 8. Build highlights\nconst highlights = metadata.discussion_highlights\n  ? (Array.isArray(metadata.discussion_highlights) ? metadata.discussion_highlights.map(h => `• ${h}`).join('\\n') : `• ${metadata.discussion_highlights}`)\n  : 'None recorded';\n\nconst slackPayload = {\n  blocks: [\n    {\n      type: \"header\",\n      text: {\n        type: \"plain_text\",\n        text: `📋 Meeting Summary: ${metadata.meeting_title || 'Sprint Planning'}`\n      }\n    },\n    {\n      type: \"context\",\n      elements: [{\n        type: \"mrkdwn\",\n        text: `📅 *Date:* ${metadata.meeting_date || 'Today'}  |  👥 *Participants:* ${metadata.participants || 'Team'}`\n      }]\n    },\n    { type: \"divider\" },\n    {\n      type: \"section\",\n      text: {\n        type: \"mrkdwn\",\n        text: `*🎯 Key Decisions:*\\n${decisions}`\n      }\n    },\n    {\n      type: \"section\",\n      text: {\n        type: \"mrkdwn\",\n        text: `*🎫 Action Items (${tickets.length} tickets created):*\\n${ticketLines}`\n      }\n    },\n    {\n      type: \"section\",\n      text: {\n        type: \"mrkdwn\",\n        text: `*💡 Discussion Highlights:*\\n${highlights}`\n      }\n    },\n    { type: \"divider\" },\n    {\n      type: \"context\",\n      elements: [{\n        type: \"mrkdwn\",\n        text: \"🤖 _Auto-generated by Meeting Automation Pipeline (n8n)_\"\n      }]\n    }\n  ]\n};\n\nreturn [{ json: slackPayload }];\n"
